# Expo/React Native need a flat-ish layout for Metro resolution; keep hoisting.
node-linker=hoisted
shamefully-hoist=true
strict-peer-dependencies=false
# Mobile-only optional peers (expo-*, react-native-*) are installed in apps/mobile,
# not hoisted into the root — keep auto-install-peers off so they don't leak here.
auto-install-peers=false
