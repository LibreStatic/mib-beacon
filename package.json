{
  "name": "mibbeacon",
  "version": "0.0.1-beta.1",
  "private": true,
  "description": "Open-source cross-platform SNMP toolkit",
  "homepage": "https://librestatic.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/LibreStatic/mibbeacon.git"
  },
  "author": "LibreStatic",
  "license": "GPL-3.0-or-later",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.33.2",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "unrs-resolver",
      "electron"
    ]
  },
  "scripts": {
    "dev:desktop": "pnpm --filter @mibbeacon/desktop dev",
    "dev:mobile": "pnpm --filter @mibbeacon/mobile android",
    "dev:server": "pnpm --filter @mibbeacon/server dev",
    "typecheck": "pnpm -r --if-present typecheck",
    "lint": "eslint .",
    "test": "vitest run",
    "build:desktop": "pnpm --filter @mibbeacon/desktop build",
    "dist:desktop": "pnpm --filter @mibbeacon/desktop dist",
    "release:prepare": "node dev/license-audit.mjs",
    "verify:licenses": "node dev/license-audit.mjs --check",
    "verify:artifacts": "node dev/scan-release-artifacts.mjs apps/desktop/out apps/mobile/android/app/build/outputs/apk/release apps/mobile/android/app/build/outputs/bundle/release",
    "audit:linux-packages": "dev/audit/linux-package-smoke.sh",
    "audit:flatpak-interactive": "python3 dev/audit/flatpak-interactive-smoke.py",
    "audit:live-resolver": "tsx dev/audit/live-resolver-sources.ts --output docs/audits/live-resolver-sources.json",
    "verify:release-metadata": "vitest run tests/release-identity.test.ts",
    "spike:engine": "pnpm --filter @mibbeacon/core spike",
    "corpus:fetch": "tsx dev/corpus/fetch-corpus.ts",
    "corpus": "tsx dev/corpus/run-corpus.ts",
    "audit:artifact-identity": "dev/audit/artifact-identity-smoke.sh",
    "audit:ubuntu-vm-appimage": "dev/audit/ubuntu-vm-appimage-smoke/run.sh"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@types/node": "^22.10.5",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "eslint": "^9.18.0",
    "eslint-import-resolver-typescript": "^3.7.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "prettier": "^3.4.2",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.4",
    "tslib": "^2.8.1",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0",
    "vitest": "^3.0.2",
    "tsx": "^4.19.2"
  }
}
