{
  "name": "@mibbeacon/server",
  "version": "0.0.1-beta.1",
  "private": true,
  "license": "GPL-3.0-or-later",
  "description": "MIB Beacon — SNMP toolkit LAN server (headless engine + web UI)",
  "type": "module",
  "scripts": {
    "build": "pnpm build:web && pnpm build:server",
    "build:server": "esbuild src/server.ts --bundle --platform=node --target=node22 --format=cjs --define:import.meta.dirname=__dirname --outfile=dist/server.cjs",
    "build:web": "vite build",
    "start": "node dist/server.cjs",
    "dev": "vite build && node --import tsx src/server.ts",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json"
  },
  "dependencies": {
    "@mibbeacon/app": "workspace:*",
    "@mibbeacon/core": "workspace:*",
    "@mibbeacon/transport": "workspace:*",
    "@mibbeacon/ui": "workspace:*",
    "net-snmp": "^3.26.3",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native-web": "^0.21.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/ws": "^8.5.13",
    "tsx": "^4.19.2",
    "vite": "^6.0.7"
  }
}
