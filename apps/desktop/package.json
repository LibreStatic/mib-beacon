{
  "name": "@omc/desktop",
  "version": "0.0.0",
  "private": true,
  "license": "GPL-3.0-or-later",
  "description": "Open MIB Catalog — desktop (Electron + react-native-web)",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "spike:crypto": "electron-vite build && electron out/main/index.js --probe-crypto"
  },
  "dependencies": {
    "@omc/app": "workspace:*",
    "@omc/core": "workspace:*",
    "@omc/transport": "workspace:*",
    "@omc/ui": "workspace:*",
    "net-snmp": "^3.26.3",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native-web": "^0.21.0"
  },
  "devDependencies": {
    "electron": "^37.10.3",
    "electron-vite": "^3.1.0",
    "vite": "^6.0.7"
  }
}
