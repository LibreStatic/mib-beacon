{
  "name": "@mibbeacon/desktop",
  "version": "0.1.0-beta.1",
  "private": true,
  "license": "GPL-3.0-or-later",
  "description": "MIB Beacon — SNMP toolkit for desktop (Electron + react-native-web)",
  "desktopName": "com.librestatic.mibbeacon",
  "author": {
    "name": "LibreStatic",
    "url": "https://librestatic.com"
  },
  "homepage": "https://librestatic.com",
  "packageManager": "pnpm@10.33.2",
  "repository": {
    "type": "git",
    "url": "https://github.com/LibreStatic/mib-beacon.git"
  },
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "pack": "pnpm build && electron-builder --dir",
    "dist": "pnpm build && electron-builder",
    "dist:linux": "pnpm build && electron-builder --linux AppImage deb rpm --x64 --arm64 --publish never",
    "dist:windows": "pnpm build && electron-builder --win nsis --x64 --publish never",
    "dist:mac": "pnpm build && electron-builder --mac dmg --x64 --arm64 --publish never",
    "start": "electron-vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "spike:crypto": "electron-vite build && electron out/main/index.js --probe-crypto"
  },
  "build": {
    "icon": "../../assets/brand/mib-beacon.png",
    "appId": "com.librestatic.mibbeacon",
    "electronVersion": "37.10.3",
    "executableName": "mib-beacon",
    "productName": "MIB Beacon",
    "asar": true,
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "artifactName": "MIB-Beacon-${version}-${os}-${arch}.${ext}",
    "afterSign": "scripts/notarize.cjs",
    "fileAssociations": [
      {
        "ext": "mib",
        "name": "SNMP MIB module",
        "role": "Editor"
      },
      {
        "ext": "my",
        "name": "SMI MIB module",
        "role": "Editor"
      },
      {
        "ext": "smi",
        "name": "SMI module",
        "role": "Editor"
      }
    ],
    "linux": {
      "target": [
        "AppImage",
        "deb",
        "rpm"
      ],
      "category": "Network",
      "maintainer": "LibreStatic",
      "synopsis": "Cross-platform SNMP toolkit",
      "syncDesktopName": true
    },
    "deb": {
      "packageName": "mib-beacon",
      "depends": [
        "libgtk-3-0",
        "libnotify4",
        "libnss3",
        "libxss1",
        "libxtst6",
        "xdg-utils",
        "libatspi2.0-0",
        "libuuid1",
        "libsecret-1-0",
        "libasound2t64 | libasound2"
      ]
    },
    "rpm": {
      "packageName": "mib-beacon"
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowToChangeInstallationDirectory": true
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "category": "public.app-category.developer-tools"
    },
    "publish": {
      "provider": "github",
      "releaseType": "prerelease"
    }
  },
  "dependencies": {
    "@mibbeacon/app": "workspace:*",
    "@mibbeacon/core": "workspace:*",
    "@mibbeacon/transport": "workspace:*",
    "@mibbeacon/ui": "workspace:*",
    "electron-updater": "^6.8.9",
    "net-snmp": "^3.26.3",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native-web": "^0.21.0"
  },
  "devDependencies": {
    "@electron/notarize": "^3.1.1",
    "electron": "^37.10.3",
    "electron-builder": "26.15.3",
    "electron-builder-squirrel-windows": "26.15.3",
    "electron-vite": "^3.1.0",
    "vite": "^6.0.7"
  }
}
