{
  "name": "@omc/desktop",
  "version": "0.0.0",
  "private": true,
  "license": "GPL-3.0-or-later",
  "description": "Open MIB Catalog — desktop (Electron + react-native-web)",
  "desktopName": "com.librestatic.openmibcatalog",
  "author": {
    "name": "LibreStatic",
    "url": "https://librestatic.com"
  },
  "homepage": "https://librestatic.com",
  "packageManager": "pnpm@10.33.2",
  "repository": {
    "type": "git",
    "url": "https://github.com/LibreStatic/openmibcatalog.git"
  },
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "pack": "pnpm build && electron-builder --dir",
    "dist": "pnpm build && electron-builder",
    "dist:linux": "pnpm build && electron-builder --linux AppImage deb rpm --x64 --arm64 --publish never",
    "dist:windows": "pnpm build && electron-builder --win nsis --x64 --publish never",
    "dist:mac": "pnpm build && electron-builder --mac dmg --x64 --arm64 --publish never",
    "start": "electron-vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "spike:crypto": "electron-vite build && electron out/main/index.js --probe-crypto"
  },
  "build": {
    "appId": "com.librestatic.openmibcatalog",
    "electronVersion": "37.10.3",
    "executableName": "open-mib-catalog",
    "productName": "Open MIB Catalog",
    "asar": true,
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "artifactName": "Open-MIB-Catalog-${version}-${os}-${arch}.${ext}",
    "fileAssociations": [
      {
        "ext": "mib",
        "name": "SNMP MIB module",
        "role": "Editor"
      },
      {
        "ext": "my",
        "name": "SMI MIB module",
        "role": "Editor"
      },
      {
        "ext": "smi",
        "name": "SMI module",
        "role": "Editor"
      }
    ],
    "linux": {
      "target": [
        "AppImage",
        "deb",
        "rpm"
      ],
      "category": "Network",
      "maintainer": "LibreStatic",
      "synopsis": "Cross-platform SNMP toolkit",
      "syncDesktopName": true
    },
    "deb": {
      "packageName": "open-mib-catalog"
    },
    "rpm": {
      "packageName": "open-mib-catalog"
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "category": "public.app-category.developer-tools"
    },
    "publish": {
      "provider": "github",
      "releaseType": "draft"
    }
  },
  "dependencies": {
    "@omc/app": "workspace:*",
    "@omc/core": "workspace:*",
    "@omc/transport": "workspace:*",
    "@omc/ui": "workspace:*",
    "net-snmp": "^3.26.3",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native-web": "^0.21.0"
  },
  "devDependencies": {
    "electron": "^37.10.3",
    "electron-builder": "26.15.3",
    "electron-builder-squirrel-windows": "26.15.3",
    "electron-vite": "^3.1.0",
    "vite": "^6.0.7"
  }
}
