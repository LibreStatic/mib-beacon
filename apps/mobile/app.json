{
  "expo": {
    "name": "Open MIB Catalog",
    "slug": "open-mib-catalog",
    "version": "0.0.0",
    "orientation": "default",
    "scheme": "openmibcatalog",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "android": {
      "package": "org.openmibcatalog.app"
    },
    "ios": {
      "bundleIdentifier": "org.openmibcatalog.app",
      "supportsTablet": true
    },
    "plugins": [
      "expo-dev-client",
      "expo-sqlite",
      "expo-secure-store",
      [
        "react-native-quick-crypto",
        { "sodiumEnabled": false }
      ]
    ]
  }
}
