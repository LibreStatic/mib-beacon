{
  "expo": {
    "name": "MIB Beacon",
    "slug": "mib-beacon",
    "version": "0.0.0",
    "orientation": "default",
    "scheme": "mibbeacon",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "android": {
      "package": "com.librestatic.mibbeacon"
    },
    "ios": {
      "bundleIdentifier": "com.librestatic.mibbeacon",
      "supportsTablet": true
    },
    "plugins": ["expo-dev-client", "expo-sqlite", "expo-secure-store"]
  }
}
