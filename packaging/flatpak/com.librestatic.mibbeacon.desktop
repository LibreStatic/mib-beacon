[Desktop Entry]
Name=MIB Beacon
Comment=Browse MIBs and work with SNMP devices
Exec=mib-beacon %F
Icon=com.librestatic.mibbeacon
Terminal=false
Type=Application
Categories=Network;Development;
# shared-mime-info classifies .smi as SMIL; claim both names and validate SMI content locally.
MimeType=application/x-mib;text/x-smi;application/smil+xml;
StartupWMClass=MIB Beacon
X-Flatpak=com.librestatic.mibbeacon
